[Unit]
Description=SmartDoc AI Backend
After=network.target redis.service

[Service]
Type=simple
WorkingDirectory=/opt/smartdoc-ai/backend
EnvironmentFile=/opt/smartdoc-ai/backend/.env
ExecStart=/root/.local/bin/uv run uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
